{
  "name": "Image Mania",
  "image": "mcr.microsoft.com/devcontainers/base:jammy",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "true"
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [
    3000,
    3001,
    3002,
    8080,
    8081,
    8082,
    8083,
    8084,
    8085,
    8096
  ],
  "portsAttributes": {
    "3000": {
      "label": "Homepage",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Gitea",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Pi-hole Admin UI",
      "onAutoForward": "notify"
    },
    "8081": {
      "label": "qBittorrent Web UI",
      "onAutoForward": "notify"
    },
    "8082": {
      "label": "IT-Tools",
      "onAutoForward": "notify"
    },
    "8083": {
      "label": "Stirling-PDF",
      "onAutoForward": "notify"
    },
    "8084": {
      "label": "Filebrowser",
      "onAutoForward": "notify"
    },
    "8096": {
      "label": "Jellyfin Web UI",
      "onAutoForward": "notify"
    },
    "3002": {
      "label": "Uptime Kuma",
      "onAutoForward": "notify"
    },
    "8085": {
      "label": "Phase 0 Hello Server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml"
      ]
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y vim nano kitty-terminfo && echo 'Welcome to the Homelab Speedrun!' > ~/welcome.txt",
  "postStartCommand": "gh codespace ports visibility 3000:public 3001:public 3002:public 8080:public 8081:public 8082:public 8083:public 8084:public 8085:public 8096:public -c $CODESPACE_NAME || true",
  "postAttachCommand": "gh codespace ports visibility 3000:public 3001:public 3002:public 8080:public 8081:public 8082:public 8083:public 8084:public 8085:public 8096:public -c $CODESPACE_NAME || true"
}